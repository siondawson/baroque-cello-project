<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>
    {% if metaTitle %}
      {{ metaTitle }} | {{ site.name }}
    {% elseif title %}
      {{ title }} | {{ site.name }}
    {% else %}
      {{ site.defaultMetaTitle }} | {{ site.name }}
    {% endif %}
  </title>
  <meta name="description" content="{% if metaDescription %}{{ metaDescription }}{% else %}{{ site.defaultMetaDescription }}{% endif %}">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Dosis:wght@400&family=Quattrocento:wght@400&display=swap" rel="stylesheet">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>

  <header class="py-4 border-bottom">
    <div class="container">
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
        <a href="/" id="wsite-title" class="text-decoration-none text-dark">IN AUDIBLE</a>

        <nav class="wsite-menu-default">
          <ul class="nav">
            <li class="nav-item"><a class="nav-link text-dark" href="/">Welcome</a></li>
            <li class="nav-item"><a class="nav-link text-dark" href="/concept/">Concept</a></li>
            <li class="nav-item"><a class="nav-link text-dark" href="/cello/">Cello</a></li>
            <li class="nav-item"><a class="nav-link text-dark" href="/presentations/">Presentations</a></li>
            <li class="nav-item"><a class="nav-link text-dark" href="/makers/">Makers</a></li>
            <li class="nav-item"><a class="nav-link text-dark" href="/thoughts/">Thoughts</a></li>
            <li class="nav-item"><a class="nav-link text-dark" href="/contact/">Contact</a></li>
          </ul>
        </nav>
      </div>
    </div>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="py-4 border-top mt-5">
    <div class="container">
      <p class="mb-0">&copy; {{ site.name }}</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
